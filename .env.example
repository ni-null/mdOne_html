# MDOne HTML Packager - Environment Configuration
# Copy this file to .env and customize values for your environment

# ═══════════════════════════════════════════════════════════════════════════════
# ⚙️ CONFIGURATION PRIORITY (Highest to Lowest)
# ═══════════════════════════════════════════════════════════════════════════════
# 1. Command-line parameters   (highest priority)
#    Example: python main.py --template normal --locale zh-TW --output docs.html
#
# 2. Environment variables from .env file
#    Example: LOCALE=zh-TW in this file
#
# 3. Built-in defaults         (lowest priority)
#    Used when .env is missing or variable is not set

# ═══════════════════════════════════════════════════════════════════════════════
# 📖 COMMAND-LINE PARAMETERS (can override .env values below)
# ═══════════════════════════════════════════════════════════════════════════════
# --source DIR           Override MARKDOWN_SOURCE_DIR
# --output FILE          Override OUTPUT_FILE
# --template NAME        Override DEFAULT_TEMPLATE
# --locale CODE          Override LOCALE
#
# Example:
#   python main.py --template minimal --locale zh-TW --output build/docs.html --source ./docs

# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 ENVIRONMENT VARIABLES (can be overridden by CLI parameters)
# ═══════════════════════════════════════════════════════════════════════════════

# === Markdown Source & Output ===
# Directory containing .md files to process
MARKDOWN_SOURCE_DIR=./markdown

# Output filename for generated HTML
OUTPUT_FILE=system_guide.html

# === Template Settings ===
# Default template name (subdirectory under templates/)
DEFAULT_TEMPLATE=normal

# Root directory containing templates
TEMPLATES_DIR=templates

# === HTML Generation ===
# Whether to minify output HTML (true/false)
MINIFY_HTML=true

# Comma-separated list of markdown-py extensions to use
# Available: tables, fenced_code, nl2br, sane_lists, attr_list, extra, codehilite, etc.
MARKDOWN_EXTENSIONS=tables,fenced_code,nl2br,sane_lists,attr_list

# === Page Metadata ===
# Page title shown in browser tab and header
SITE_TITLE=ASK

# Initial theme mode: 'light' or 'dark'
THEME_MODE=light

# === Internationalization ===
# Language/locale code: 'en' or 'zh-TW'
LOCALE=en

# Build date (format: YYYY.MM.DD). Leave empty to auto-fill today's date
BUILD_DATE=

# === Configuration File Paths ===
# Path to locale resources directory (default: locales/)
LOCALES_DIR=locales

# Config file for template-specific settings (optional, inside each template dir)
TEMPLATE_CONFIG_FILE=template.config.json

# ═══════════════════════════════════════════════════════════════════════════════
# 📝 USAGE EXAMPLES
# ═══════════════════════════════════════════════════════════════════════════════

# 1. Use .env defaults:
#    python main.py

# 2. Override specific settings with parameters:
#    python main.py --locale zh-TW

# 3. Use pure parameters (no .env needed):
#    python main.py --source ./docs --template minimal --locale en --output build.html

# 4. Multiple parameter overrides:
#    python main.py --template normal --locale zh-TW --output output/docs.html

# ═══════════════════════════════════════════════════════════════════════════════
# 💡 NOTES
# ═══════════════════════════════════════════════════════════════════════════════
# - If .env doesn't exist, built-in defaults are used
# - If .env exists, values here are used as defaults
# - Command-line parameters override both .env and built-in defaults
# - At least one of MARKDOWN_SOURCE_DIR or --source must point to a valid directory
